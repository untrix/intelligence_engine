# Intelligence Engine configuration
INTELLIGENCE_ENGINE_DEBUG=false
INTELLIGENCE_ENGINE_HOST=0.0.0.0
INTELLIGENCE_ENGINE_PORT=8001
# Workspace root: relative local-file tool paths resolve here (optional)
# INTELLIGENCE_ENGINE_WORKSPACE_ROOT=/Users/you/AgentPlatform/workspace
# Legacy alias still supported:
# INTELLIGENCE_ENGINE_HOME_DIR=/Users/you/AgentPlatform/workspace
INTELLIGENCE_ENGINE_DATA_DIR=./data
# Zapier MCP credentials are stored in the app database via Integrations (not env vars).
